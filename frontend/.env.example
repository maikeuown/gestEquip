# Backend API URL (used by Next.js rewrites and API client)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# WebSocket backend URL for Socket.io (must be full URL in production)
# In development, leave unset or set to http://localhost:3001
# In production (Vercel), set to your backend deployment URL, e.g.:
# NEXT_PUBLIC_WS_URL=https://your-backend-api.vercel.app
NEXT_PUBLIC_WS_URL=

# Google OAuth Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
